            </li>

            <li class="flex items-center gap-3">
                <span>{{ app.user.username }}</span>
                <div class="relative">
                    <img src="{{ asset(photoPath(app.user.photo)) }}"
                         alt="{{ app.user.photo }}"
                         class="w-14 h-14 rounded-full border-2 border-[#7349F3] cursor-pointer" id="profilePicture">
                    <ul class="absolute bg-white border border-slate-200 rounded-lg shadow-xl w-48 top-full right-0 mt-2 hidden"
                        id="menu">
                        <li><a href="{{ path('app_user_show', {'id' : app.user.id}) }}"
                               class="block px-4 py-2 hover:bg-violet-50">Profile</a></li>
                        <li><a href="{{ path('app_logout') }}" class="block px-4 py-2 hover:bg-violet-50 text-red-500">Logout</a>
                        </li>
                    </ul>
                </div>
            </li>
        </ul>
    </nav>
</div>

<script>
    const photo = document.getElementById('profilePicture');
    const menu = document.getElementById('menu');

    // Ouvre le menu au click
    photo.addEventListener('click', (e) => {
        e.stopPropagation(); // Empêche le clic de remonter directement à la window (sinon il s'ouvre pas)
        menu.classList.toggle('hidden');
    });

    // Ferme le menu si le clic est ailleurs que sur le menu
    window.addEventListener('click', (e) => {
        if (!menu.contains(e.target)) {
            menu.classList.add('hidden');
        }
    });
</script>
