{% extends 'base.html.twig' %}

{% block title %}Users{% endblock %}

{% block body %}

    <div
        class="absolute top-[0%] right-[10%] w-[300px] h-[600px] bg-[#FF7F00]/20 rounded-[50%] blur-[50px] pointer-events-none"></div>

    <div
        class="absolute bottom-[-10%] right-[10%] w-[400px] h-[500px] bg-[#256AFF]/30 rounded-[50%] blur-[50px] pointer-events-none"></div>

    <div
        class="absolute top-[-30%] left-[0%] w-[500px] h-[600px] bg-[#7349F3]/20 rounded-[50%] blur-[50px] pointer-events-none"></div>
    <h1 class="text-3xl font-bold text-gray-800 mb-6 mx-auto w-full max-w-4xl px-4 mt-16">Users list</h1>
    {% if is_granted('ROLE_ADMIN') and is_granted('ROLE_USER') %}
        <div class="flex justify-center px-4">
            <div class="flex flex-col items-start w-full max-w-4xl">
                <button
                    class="border border-slate-200 rounded-lg mb-4 py-2 px-4 mt-2 text-white bg-[#7349F3] hover:bg-violet-600 hover:text-white cursor-pointer">
                    <a href="{{ path('app_user_new') }}">Create new user </a>
                </button>
            </div>
        </div>
    {% endif %}

    <div class="flex justify-center p-4 mb-16">

        <div class="overflow-auto max-h-[700px] shadow-md sm:rounded-lg border w-full max-w-4xl">

            <table class="w-full text-sm text-left text-gray-500">
                <thead class="text-xs text-white uppercase bg-[#7349F3] sticky top-0 z-10">
                <tr>
                    <th scope="col" class="px-6 py-3">Id</th>
                    <th scope="col" class="px-6 py-3">Email</th>
                    <th scope="col" class="px-6 py-3">Username</th>
                    <th scope="col" class="px-6 py-3">Roles</th>
                    <th scope="col" class="px-6 py-3">Activity Status</th>
                    <th scope="col" class="px-6 py-3">Action</th>
                </tr>
                </thead>
                <tbody>
                {% for user in users %}
                    {#            <tr class="bg-white border-b hover:bg-blue-50"> #}
                    <td class="px-6 py-4">{{ user.id }}</td>
                    <td class="px-6 py-4">{{ user.email }}</td>
                    <td class="px-6 py-4">{{ user.username }}</td>
                    <td class="px-6 py-4">{{ user.roles ? user.roles|json_encode : '' }}</td>
                    <td class="px-6 py-4">{{ user.active }}</td>
                    <td class="px-6 py-4">
                        <div class="flex flex-col">
                            <a href="{{ path('app_user_show', {'id': user.id}) }}"
                               class="hover:text-blue-600"
                            >Show User</a>

                            {% if user.active == true and is_granted('ROLE_ADMIN') %}
                                <a onclick="return confirm('Do you really want to DEACTIVATE user: {{ user.username }} ?')"
                                   href="{{ path('app_user_deactivate_admin', {'id': user.id}) }}"
                                   class="hover:text-violet-600"
                                >Deactivate User</a>
                            {% elseif user.active == false and is_granted('ROLE_ADMIN') %}
                                <a onclick="return confirm('Do you really want to ACTIVATE user: {{ user.username }} ?')"
                                   href="{{ path('app_user_activate_admin', {'id': user.id}) }}"
                                   class="hover:text-violet-500"
                                >Activate User</a>
                            {% endif %}
                            {% if is_granted("ROLE_ADMIN") %}
                                <a onclick="return confirm('Do you really want to DELETE user: {{ user.username }} PERMANENTLY?')"
                                   href="{{ path('app_user_delete', { 'id':user.id }) }}"
                                   class="hover:text-red-500"
                                >Delete User</a>
                            {% endif %}
                        </div>
                    </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5">no records found</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

{% endblock %}
