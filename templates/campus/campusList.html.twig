{% extends 'base.html.twig' %}

{% block body %}
    <div
        class="absolute top-[0%] right-[30%] w-[300px] h-[600px] bg-[#FF0000]/25 rounded-[50%] blur-[50px] pointer-events-none -z-10"></div>
    <div
        class="absolute bottom-[-0%] right-[30%] w-[400px] h-[500px] bg-[#6B00C9]/15 rounded-[50%] blur-[50px] pointer-events-none -z-10"></div>
    <section class="flex flex-col justify-center p-4 m-16" >
        <h2 class="text-3xl font-bold text-gray-800 mb-6 mx-auto w-full max-w-4xl">
            Campus
        </h2>
        <div class=" mx-auto w-full max-w-4xl bg-white rounded-lg p-4 relative z-10 w-full" >
        <div class=" mx-auto w-full max-w-4xl">


        {{ form_start(filterSearch)}}
        {{ form_row(filterSearch.searchTerm, {'attr':{'class':'
        w-full
        text-sm px-3 py-2
        p-4
        rounded-lg
        border border-slate-200
        focus:border-violet-400 outline-none
        mt-2
            '}}) }}
        <button
            class="border
                border-slate-200
                rounded-lg
                cursor-pointer
                mb-4
                py-2
                px-4
                mt-2
                text-white
                bg-[#7349F3]
                hover:bg-violet-600
                hover:text-white"
        > Find campus</button>
        {{ form_end(filterSearch, { render_rest: false })}}
        <div class="overflow-auto
                    max-w-full max-h-[700px]
                    shadow-md
                    sm:rounded-lg
                    mx-auto max-w-4xl w-full
                    border">
            <table class="w-full text-sm text-left text-gray-500">
                <thead class="text-xs text-white uppercase bg-[#7349F3] sticky top-0 z-10">
                <tr>
                    <th scope ="col" class="px-6 py-3">Name</th>
                    <th scope ="col" class="px-6 py-3">Actions</th>
                </tr>
                </thead>
                <tbody>
                {%  set displayCities = searchedCampus is not empty ? searchedCampus : campus  %}
                {%for campus in displayCities %}
                    <tr class="bg-white border-b hover:bg-blue-50">
                        <td class="px-6 py-4">{{ campus.name }}</td>
                        <td class="px-6 py-4 justify-evenly"><a onclick="return confirm('Are you sure you want to delete this campus ?')" href="{{ path('campus_delete' , {'id':campus.id}) }}"
                            class="hover:text-red-500"
                            >Delete</a>
                            <a onclick="confirm('Are you sure you want to edit this campus ?')" href="{{ path('campus_edit' , {'id':campus.id}) }}"
                               class="hover:text-violet-500"
                            >Edit</a>
                        </td>

                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
  </div>
</section>
    <br>

{% endblock %}

{% block title %}
    Campus
{% endblock %}

