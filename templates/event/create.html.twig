{% extends 'base.html.twig' %}

{% block body %}
<div class="bg-[radial-gradient(circle,rgba(238,174,202,1)_12%,rgba(255,255,255,1)_100%)]
            min-h-screen
            flex items-center justify-center p-4">
    {% embed 'views/form/template-form.html.twig' with { form : eventForm } %}
        {% block formTitle %} Create an event ! {% endblock %}
        {% block buttonLabel %}
            <div class="btn-group flex gap-4 mt-4">
                {{ form_widget(form.save, {'attr':{'class':'
                border
                border-slate-200
                rounded-lg
                py-2
                px-4
                mt-2
                bg-violet-500
                cursor-pointer
                transition-colors
                hover:bg-violet-600
                hover:text-white
'}}) }}
                {{ form_widget(form.publish, {'attr':{'class':'
                border
                border-slate-200
                rounded-lg
                py-2
                px-4
                mt-2
                bg-green-500
                cursor-pointer
                transition-colors
                hover:bg-green-600
                hover:text-white
'}}) }}
                {{ form_widget(form.cancel, {'attr':{'class':'
                border
                border-slate-200
                rounded-lg
                py-2
                px-4
                mt-2
                bg-red-500
                cursor-pointer
                transition-colors
                hover:bg-red-600
                hover:text-white
'}}) }}
            </div>

        {% endblock %}
    {% endembed %}
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const dateStart = document.getElementById('event_dateStartHour');
            const dateEnd = document.getElementById('event_dateEndHour');
            const deadline = document.getElementById('event_registrationDeadline');
            const form = dateStart?.closest('form');

            // Obtenir la date/heure actuelle au format datetime-local
            function getNow() {
                const now = new Date();
                // Arrondir à la minute courante
                now.setSeconds(0, 0);
                return now.toISOString().slice(0, 16); // "YYYY-MM-DDTHH:MM"
            }

            function validate() {
                const now = getNow();
                const start = dateStart?.value ? new Date(dateStart.value) : null;
                const end = dateEnd?.value ? new Date(dateEnd.value) : null;
                const dead = deadline?.value ? new Date(deadline.value) : null;

                // Mettre à jour les contraintes min/max
                if (dateStart) dateStart.min = now;
                if (deadline) deadline.min = now;
                if (dateStart) dateStart.max = dateEnd?.value || '';
                if (deadline) deadline.max = dateStart?.value || '';
                if (dateEnd) dateEnd.min = dateStart?.value || now;

                // Valider dateEnd > dateStart
                if (start && end && end <= start) {
                    dateEnd.setCustomValidity("La date de fin doit être postérieure à la date de début.");
                    dateStart.setCustomValidity("La date de début doit être antérieure à la date de fin.");
                } else {
                    dateEnd.setCustomValidity('');
                    dateStart.setCustomValidity('');
                }

                // Valider deadline <= dateStart
                if (start && dead && dead > start) {
                    deadline.setCustomValidity("La date limite d'inscription doit être antérieure ou égale à la date de début.");
                } else {
                    deadline.setCustomValidity('');
                }

                // Valider que dateStart n'est pas dans le passé
                if (start && start < new Date()) {
                    dateStart.setCustomValidity("La date de début ne peut pas être dans le passé.");
                }
            }

            validate();

            dateStart?.addEventListener('change', validate);
            dateEnd?.addEventListener('change', validate);
            deadline?.addEventListener('change', validate);

            form?.addEventListener('submit', function (e) {
                validate();
                if (!form.checkValidity()) {
                    e.preventDefault();
                    dateEnd?.reportValidity() || deadline?.reportValidity() || dateStart?.reportValidity();
                }
            });
        });

    </script>

{% endblock %}
